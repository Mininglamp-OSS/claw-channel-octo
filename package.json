{
  "name": "claw-channel-octo",
  "version": "0.2.0",
  "description": "Octo IM channel plugin for WorkBuddy Claw — direct WebSocket integration via ClawPluginHost",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "DESIGN.md"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "test": "node --test --import tsx src/__tests__/*.test.ts"
  },
  "dependencies": {
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.18.1",
    "tsup": "^8.3.0",
    "tsx": "^4.22.3",
    "typescript": "^5.6.0",
    "ws": "^8.21.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
